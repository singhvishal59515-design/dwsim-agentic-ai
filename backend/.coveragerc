[run]
source = .
omit =
    tests/*
    ablation.py
    ablation_paper_table.py
    benchmark_report.py
    benchmark_tasks.py
    run_benchmark.py
    _fossee_*.py
    _smoke_*.py
    _kill*.py
    suppress_dotnet_output.py
    dwsim_bridge_v2.py
    dwsim_gui_bridge.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    \.\.\.$
