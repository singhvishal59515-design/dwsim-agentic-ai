# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: groq | ollama | openai | anthropic   (Gemini is no longer supported)
LLM_PROVIDER=groq

# ── API Keys ────────────────────────────────────────────────────────────────
# Fill in ALL keys you have — the system auto-falls back across providers
# when one hits rate limits or errors (groq → openai → anthropic)
GROQ_API_KEY=gsk_YOUR_KEY_HERE
# OPENAI_API_KEY=sk-your_openai_key
# ANTHROPIC_API_KEY=sk-ant-your_key

# ── Optional: override the default model for your provider ──────────────────
# LLM_MODEL=llama-3.3-70b-versatile

# ── Optional: optimisation optimum verification (Step 3.5) ──────────────────
# After an optimisation, the optimum is re-applied + re-solved and its objective
# re-read to confirm it reproduces. Costs one extra solve. Set to 0 to skip on
# very expensive flowsheets. Tolerance is the max relative re-read error.
# OPT_VERIFY_OPTIMUM=1
# OPT_VERIFY_REL_TOL=1e-3

# ── DWSIM DLL folder (auto-detected if not set) ──────────────────────────────
# DWSIM_DLL_FOLDER=C:\Users\YourName\AppData\Local\DWSIM\DWSIM

# ── API server port ──────────────────────────────────────────────────────────
PORT=8000
